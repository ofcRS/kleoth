<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>Kleoth</string>
    <key>CFBundleDisplayName</key>
    <string>Kleoth</string>
    <key>CFBundleIdentifier</key>
    <string>dev.kleoth.app</string>
    <key>CFBundleExecutable</key>
    <string>Kleoth</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.4</string>
    <!-- Menu-bar agent: no Dock icon, no main window. -->
    <key>LSUIElement</key>
    <true/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- Required for the microphone TCC prompt. (Screen Recording has no
         Info.plist key — it is a system-managed prompt; system-audio capture
         via the Core Audio process-tap does not require it.) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Kleoth records your microphone to transcribe meetings locally.</string>
    <!-- Required to read a Core Audio process tap (system audio). Without this
         key the tap silently returns zeros and there is NO API to query the
         authorization status. -->
    <key>NSAudioCaptureUsageDescription</key>
    <string>Kleoth records system audio (the other participants) to transcribe your meetings locally.</string>
    <!-- Optional: name meetings from the overlapping calendar event. macOS 14+
         requires the full-access key for requestFullAccessToEvents(); the legacy
         key is kept for older systems. -->
    <key>NSCalendarsFullAccessUsageDescription</key>
    <string>Kleoth reads your calendar to name meetings from the event you're in. This is optional.</string>
    <key>NSCalendarsUsageDescription</key>
    <string>Kleoth reads your calendar to name meetings from the event you're in. This is optional.</string>
    <!-- kleoth:// URL scheme: record / stop / toggle / summarize-latest /
         slack-latest — callable by Raycast, Shortcuts, `open`, scripts, etc. -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>dev.kleoth.app</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>kleoth</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
